# BillBuddy Environment Variables
# Copy this to .env and fill in your values

# Railway provides this automatically when you add a Postgres plugin
DATABASE_URL=postgresql://username:password@host:port/database

# Server port (Railway sets this automatically)
PORT=3001

# Environment
NODE_ENV=development

# JWT secret for auth tokens (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Google OAuth (optional - get from https://console.cloud.google.com)
# REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Anthropic API key for AI Insights (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Plaid (get from https://dashboard.plaid.com)
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-secret
PLAID_ENV=sandbox
